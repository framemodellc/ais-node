# Copy this file to .env and fill in your values
# .env is git-ignored. Never commit real credentials.

SSH_HOST=192.168.1.xxx       # IP address of your Raspberry Pi
SSH_PORT=22
SSH_USER=ais                 # SSH username on the Pi
SSH_PASS=your_password_here  # SSH password on the Pi
LOG_PATH=/var/log/ais-forwarder.log  # path to AIS log on the Pi
PORT=3000                    # local port for the web HUD
